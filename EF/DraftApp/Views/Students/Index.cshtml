@model List<Student>

@{
    ViewData["Title"] = "Index";
    var q = (ViewBag.querry as string) ?? "";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="tblbody">
@foreach (var item in Model) {
        <tr>
            <td>
                @item.StudentId
            </td>
            <td>
                @item.FullName
            </td>
            <td>
                @item.Email
            </td>
            <td>
                @item.Status
            </td>
            <td>
                <a class="btn" asp-action="Edit" asp-route-id="@item.StudentId">Edit</a> |
                <a class="btn" asp-action="Delete" asp-route-id="@item.StudentId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
