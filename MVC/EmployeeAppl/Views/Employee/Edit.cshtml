@model EmployeeAppl.Models.Employee

<h2>Edit Employee</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Address"></label>
        <input asp-for="Address" />
        <span asp-validation-for="Address" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Adhaar"></label>
        <input asp-for="Adhaar" />
        <span asp-validation-for="Adhaar" style="color:red"></span>
    </div>

    <div>
        <label asp-for="DateOfBirth"></label>
        <input asp-for="DateOfBirth" type="date" />
        <span asp-validation-for="DateOfBirth" style="color:red"></span>
    </div>

    <button type="submit">Update</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}